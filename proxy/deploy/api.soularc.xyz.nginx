# nginx vhost for the Soularc proxy API.
# Install once on the server (see ../../CLAUDE.md):
#   scp proxy/deploy/api.soularc.xyz.nginx root@68.183.142.183:/etc/nginx/sites-available/api.soularc.xyz
#   ln -s /etc/nginx/sites-available/api.soularc.xyz /etc/nginx/sites-enabled/api.soularc.xyz
#   nginx -t && systemctl reload nginx
#   certbot --nginx -d api.soularc.xyz   # adds the listen 443 / ssl_certificate lines
server {
    listen 80;
    listen [::]:80;
    server_name api.soularc.xyz;

    location / {
        proxy_pass http://127.0.0.1:3003;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
