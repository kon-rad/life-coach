PORT=3000
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=base64-encoded-service-account-json
MASTER_ENCRYPTION_KEY=64-char-hex-random-key
TOGETHER_AI_API_KEY=
VAPI_API_KEY=
VAPI_PRIVATE_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=
VAPI_TOOLS_URL=https://api.soularc.xyz/webhooks/vapi/tools
REVENUECAT_WEBHOOK_SECRET=
# RevenueCat Secret API key (sk_...) — required for the /user/redeem-coupon promo grant.
# RevenueCat → Project Settings → API Keys → Secret key. NOT the public appl_ SDK key.
REVENUECAT_SECRET_API_KEY=
# Optional: entitlement id granted by the coupon (defaults to "premium").
# REVENUECAT_ENTITLEMENT_ID=premium
DATABASE_URL=postgresql://localhost:5432/livecoach
# Dev only: when "true", skips the subscription/free-tier chat rate limit. NEVER set in production.
DEV_MODE=false
